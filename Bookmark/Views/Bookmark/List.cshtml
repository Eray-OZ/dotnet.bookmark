@model List<Bookmark.Models.BookmarkItem>





<body class="dark bg-background text-on-surface font-body-md antialiased min-h-screen flex flex-col">
<div class="flex justify-between items-center px-margin-mobile md:px-margin-desktop py-6">
<h1 class="font-headline-lg text-headline-lg text-on-surface">Bookmarks</h1>
<div class="flex items-center gap-8">
<button onclick="window.location.href='/Bookmark/Add'" class="bg-primary text-on-primary px-6 py-2.5 rounded-xl font-label-md text-label-md hover:shadow-lg active:scale-95 transform transition-all duration-150 flex items-center gap-2">
<span class="material-symbols-outlined">add</span>
New Bookmark
</button>
<button onclick="window.location.href='/Bookmark/Favorites'" class="hover:scale-125 transition-transform flex items-center gap-2" title="Favorites">
<span class="material-symbols-outlined text-outline text-2xl">star</span>
<span class="text-on-surface font-label-md text-label-md">Favorites</span>
</button>
</div>
</div>





<!-- Cards -->
<main class="flex-grow max-w-container-max-width mx-auto w-full px-margin-mobile md:px-margin-desktop py-10">
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-gutter" id="bookmark-grid">
@foreach(BookmarkItem bookmark in Model) {
<article class="bookmark-card group relative flex flex-col bg-surface-container-lowest rounded-xl border border-outline-variant shadow-sm hover:-translate-y-1 hover:shadow-md transition-all duration-300">

<div class="p-5 flex flex-col flex-grow">
<div class="flex justify-between items-start mb-2">
<span class="px-2 py-0.5 bg-secondary-container text-on-secondary-container rounded font-label-sm text-label-sm">@bookmark.Category</span>
<button class="favorite-toggle hover:scale-110 transition-transform">

@if (bookmark.Favorite)
{
<span class="material-symbols-outlined filled-icon text-primary">star</span>
}
</button>
</div>
<a href="@bookmark.Url"><h3 class="font-headline-sm text-headline-sm text-on-surface mb-1 group-hover:text-primary transition-colors">@bookmark.Title</h3></a>
<p class="text-on-surface-variant text-body-sm font-body-sm line-clamp-2">@bookmark.Description</p>
</div>
</article>
}





</main>
</body>