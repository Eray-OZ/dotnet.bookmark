@model Bookmark.Models.BookmarkItem



<body class="dark bg-background text-on-background font-body-md min-h-screen overflow-hidden">

<!-- Background Content (Simulated Dashboard) -->
<main class="max-w-container-max-width mx-auto px-margin-mobile md:px-margin-desktop py-8 opacity-40 select-none pointer-events-none">
<div class="flex justify-between items-center mb-8">
<h1 class="font-headline-lg text-headline-lg text-on-surface">Bookmarks</h1>
<div class="flex gap-4">
<div class="bg-surface-container h-10 w-32 rounded-xl"></div>
<div class="bg-primary h-10 w-40 rounded-xl"></div>
</div>
</div>
<div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-gutter">
<!-- Simulated Bookmark Cards -->
<div class="bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden shadow-sm">
<div class="h-40 bg-surface-container-highest"></div>
<div class="p-4 space-y-2">
<div class="h-4 bg-outline-variant w-3/4 rounded"></div>
<div class="h-3 bg-outline-variant w-1/2 rounded"></div>
</div>
</div>
<div class="bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden shadow-sm">
<div class="h-40 bg-surface-container-highest"></div>
<div class="p-4 space-y-2">
<div class="h-4 bg-outline-variant w-3/4 rounded"></div>
<div class="h-3 bg-outline-variant w-1/2 rounded"></div>
</div>
</div>
<div class="bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden shadow-sm">
<div class="h-40 bg-surface-container-highest"></div>
<div class="p-4 space-y-2">
<div class="h-4 bg-outline-variant w-3/4 rounded"></div>
<div class="h-3 bg-outline-variant w-1/2 rounded"></div>
</div>
</div>
<div class="bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden shadow-sm">
<div class="h-40 bg-surface-container-highest"></div>
<div class="p-4 space-y-2">
<div class="h-4 bg-outline-variant w-3/4 rounded"></div>
<div class="h-3 bg-outline-variant w-1/2 rounded"></div>
</div>
</div>
</div>
</main>
<!-- Modal Overlay Backdrop -->
<div class="fixed inset-0 z-[60] flex items-center justify-center modal-backdrop p-margin-mobile">
<!-- Modal Container -->
<section class="bg-surface-container-lowest w-full max-w-[560px] rounded-xl shadow-[0px_10px_15px_-3px_rgba(79,70,229,0.1)] border border-outline-variant overflow-hidden animate-in fade-in zoom-in duration-300">
<!-- Modal Header -->
<div class="px-8 pt-8 pb-4 flex justify-between items-center">
<h2 class="font-headline-md text-headline-md text-on-surface">Add New Bookmark</h2>
<button class="text-on-surface-variant hover:text-primary transition-colors" onclick="window.history.back()">
<span class="material-symbols-outlined" data-icon="close">close</span>
</button>
</div>



<!-- Modal Content (Form) -->

<form class="px-8 pb-8 space-y-6"
asp-controller="Bookmark"
asp-action="Add"
method="post"
>


<!-- Title Field -->
<div class="space-y-2">
<label class="font-label-md text-label-md text-on-surface-variant block" for="bookmark-title">Title</label>
<input asp-for="Title" class="w-full bg-surface-bright dark:bg-[#1a202c] border border-outline-variant dark:border-[#4a4758] rounded-xl px-4 py-3 text-body-md font-body-md text-on-surface dark:text-[#e0e0e0] input-focus-ring transition-all placeholder:text-outline-variant dark:placeholder:text-[#4a4758]" id="bookmark-title" placeholder="e.g., Design Inspiration 2024" type="text"/>
</div>


<!-- URL Field -->
<div class="space-y-2">
<label class="font-label-md text-label-md text-on-surface-variant flex items-center gap-1" for="bookmark-url">URL<span class="text-error">*</span>
</label>
<input asp-for="Url" class="w-full bg-surface-bright dark:bg-[#1a202c] border border-outline-variant dark:border-[#4a4758] rounded-xl px-4 py-3 text-body-md font-body-md text-on-surface dark:text-[#e0e0e0] input-focus-ring transition-all placeholder:text-outline-variant dark:placeholder:text-[#4a4758]" id="bookmark-url" placeholder="https://example.com" required="" type="url"/>
<p class="hidden text-error text-label-sm font-label-sm mt-1">Please enter a valid website address.</p>
</div>
<div class="grid grid-cols-1 md:grid-cols-2 gap-4">


<!-- Category Selection -->
<div class="space-y-2">
<label class="font-label-md text-label-md text-on-surface-variant block" for="bookmark-category">Category</label>
<div class="relative">
<select asp-for="Category" class="w-full bg-surface-bright dark:bg-[#1a202c] border border-outline-variant dark:border-[#4a4758] rounded-xl px-4 py-3 pr-12 text-body-md font-body-md text-on-surface dark:text-[#e0e0e0] input-focus-ring transition-all cursor-pointer" id="bookmark-category" style="appearance: none; -webkit-appearance: none; -moz-appearance: none; background-image: none;">
<option value="general">General</option>
<option value="design">Design</option>
<option value="tech">Technology</option>
<option value="reading">Reading List</option>
<option value="work">Work</option>
</select>
<span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-on-surface-variant" data-icon="expand_more">expand_more</span>
</div>
</div>



<!-- Favorite Toggle -->
<div class="space-y-2">
<label class="font-label-md text-label-md text-on-surface-variant block">Quick Access</label>
<label class="flex items-center gap-3 h-[50px] cursor-pointer bg-surface-bright dark:bg-[#1a202c] border border-outline-variant dark:border-[#4a4758] rounded-xl px-4 transition-colors hover:border-primary-container dark:hover:border-[#b8c5ff]">
<input asp-for="Favorite" class="w-5 h-5 rounded border-outline-variant dark:border-[#4a4758] text-primary dark:text-[#b8c5ff] focus:ring-primary-container dark:focus:ring-[#b8c5ff]" id="bookmark-favorite" type="checkbox"/>
<span class="flex items-center gap-2 text-body-md font-body-md text-on-surface dark:text-[#e0e0e0]">
<span class="material-symbols-outlined text-tertiary-container dark:text-[#ffb695]" data-icon="star" data-weight="fill" style="font-variation-settings: 'FILL' 1;">star</span>
Favorite</span>
</label>
</div>
</div>


<!-- Description Field -->
<div class="space-y-2">
<label class="font-label-md text-label-md text-on-surface-variant block" for="bookmark-description">Description</label>
<textarea asp-for="Description" class="w-full bg-surface-bright dark:bg-[#1a202c] border border-outline-variant dark:border-[#4a4758] rounded-xl px-4 py-3 text-body-md font-body-md text-on-surface dark:text-[#e0e0e0] input-focus-ring transition-all placeholder:text-outline-variant dark:placeholder:text-[#4a4758] resize-none" id="bookmark-description" placeholder="Add a brief note about this bookmark..." rows="3"></textarea>
</div>



<!-- Action Buttons -->
<div class="flex flex-col-reverse md:flex-row justify-end items-center gap-4 pt-2">
<button class="w-full md:w-auto px-6 py-3 font-label-md text-label-md text-on-surface-variant hover:text-on-surface hover:bg-surface-container transition-all rounded-xl active:scale-95 transform" type="button" onclick="window.history.back()">
Cancel</button>
<button class="w-full md:w-auto px-8 py-3 bg-primary text-on-primary font-label-md text-label-md rounded-xl hover:bg-primary-container shadow-md transition-all active:scale-95 transform flex items-center justify-center gap-2" type="submit">
<span class="material-symbols-outlined text-sm" data-icon="save">save</span>Save Bookmark</button>
</div>
</form>




</section>
</div>

<script>
  
        // Toggle focus state colors or other minor UI adjustments
        const inputs = document.querySelectorAll('input, select, textarea');
        inputs.forEach(input => {
            input.addEventListener('focus', () => {
                input.closest('.space-y-2').querySelector('label').classList.add('text-primary');
            });
            input.addEventListener('blur', () => {
                input.closest('.space-y-2').querySelector('label').classList.remove('text-primary');
            });
        });
    </script>
</body>